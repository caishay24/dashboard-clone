{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @dashboard/shared build && pnpm build:vercel-api && pnpm -r build",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "functions": {
    "api/[[...slug]].js": {
      "memory": 256,
      "maxDuration": 30,
      "includeFiles": "api/_app.mjs"
    }
  }
}
