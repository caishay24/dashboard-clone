{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build:vercel-api && cd apps/web && node ../../node_modules/vite/bin/vite.js build",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "regions": ["hnd1"],
  "installCommand": "pnpm install --no-frozen-lockfile",
  "functions": {
    "api/[[...slug]].js": {
      "memory": 256,
      "maxDuration": 30,
      "includeFiles": "api/_app.mjs"
    },
    "api/stocks/search.js": {
      "memory": 256,
      "maxDuration": 30,
      "includeFiles": "api/_app.mjs"
    },
    "api/stocks/detail.js": {
      "memory": 256,
      "maxDuration": 30,
      "includeFiles": "api/_app.mjs"
    }
  }
}
